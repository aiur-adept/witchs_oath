[node name="ExampleNoblesText" type="RichTextLabel" parent="Margin/VBox/Scroll/ContentRoot/NoblesCard/Inner"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
scroll_active = false
text = "Shown above:
- Lower Noble Trss (cost 3) plays because the 3-lane is active — no sacrifice needed.
- Higher Noble Xytzr (cost 6) cannot be paid by lanes; sacrificing a 4-Ritual + 2-Ritual (total 6) pays exactly. A 4-Ritual + 3-Ritual (total 7) would also work."

