text = "Rings"

[node name="RingsText" type="RichTextLabel" parent="Margin/VBox/Scroll/ContentRoot/RingsCard/Inner"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
scroll_active = false
text = "Rings are silver cards that attach to one of your Nobles or to an wild Bird you control.
- Each Ring reduces the cost of specific plays by 1 while it remains on the field.
- A Noble or Bird may carry multiple Rings. A stack tab beside it shows how many are attached — click it to see the Rings.
- When the host is destroyed, its attached Rings go to the crypt. A Bird with any attached Ring cannot nest.

Example Rings:
- Sybiline, Ring of Emanation — Seek and Insight cost 1 less.
- Cymbil, Ring of Occultation — Burn, Revive, and Renew cost 1 less.
- Celadon, Ring of Annihilation — Woe costs 1 less.
- Serraf, Ring of Nobles — Nobles cost 1 less.
- Sinofia, Ring of Feathers — Birds and Tears cost 1 less."

