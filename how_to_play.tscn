text = "Higher vs Lower Nobles"

[node name="NoblesText" type="RichTextLabel" parent="Margin/VBox/Scroll/ContentRoot/NoblesCard/Inner"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
scroll_active = false
text = "Nobles split into two groups based on their printed cost:

Lower Nobles (cost 4 or less) — pay only by having their cost lane active. You cannot sacrifice Rituals to play a Lower Noble; you need the matching active lane.
- Krss (cost 2), Trss (cost 3), the cost-3 Incantation Nobles, Yrss (cost 4).

Higher Nobles (cost 6 or more) — pay only by sacrificing Rituals whose values total at least the cost. Active lanes do not pay for them; you must sacrifice.
- Xytzr and Yytzr (cost 6), Aeoiu and Zytzr (cost 8).

Only one Noble may be played from hand per turn, regardless of which type."

[node name="ExampleLowerNobleRow" type="HBoxContainer" parent="Margin/VBox/Scroll/ContentRoot/NoblesCard/Inner"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 10

[node name="ExampleHigherNobleRow" type="HBoxContainer" parent="Margin/VBox/Scroll/ContentRoot/NoblesCard/Inner"]
unique_name_in_owner = true
