text = "Example shown above:
Delpha, Temple of Oracles costs 7, so sacrificing 4-Ritual + 2-Ritual + 1-Ritual pays exactly."

[node name="BirdsFightTitle" type="Label" parent="Margin/VBox/Scroll/ContentRoot"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Bird fight"

[node name="BirdsFightText" type="RichTextLabel" parent="Margin/VBox/Scroll/ContentRoot"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
scroll_active = false
text = "Once per turn during your main phase, you may start a bird fight if both players have at least one bird on the field that is not nested in a temple.
Choose any number of your birds as attackers, and exactly one opposing bird as the defender. Each side deals damage equal to its total bird power; you assign damage among your own birds on each side. Any bird whose damage is greater than or equal to its power is destroyed (sent to crypt).
Nested birds cannot be attackers or defenders.

Example (cards below): Finch attacks the opponent's Sparrow. Each has power 1, so each side deals 1 damage — both are destroyed.

Second example: Kestrel and Shrike (power 2 each) attack Hawk (power 3). Your birds deal 4 damage total, so Hawk is destroyed. Hawk deals 3 damage for you to assign among your attackers — for example 2 to Kestrel and 1 to Shrike — so Kestrel is destroyed and Shrike survives."

