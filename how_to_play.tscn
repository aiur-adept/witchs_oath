[node name="BirdsNestTitle" type="Label" parent="Margin/VBox/Scroll/ContentRoot"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Nesting"

[node name="BirdsNestText" type="RichTextLabel" parent="Margin/VBox/Scroll/ContentRoot"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
scroll_active = false
text = "Use Nest on your turn to place one of your birds under one of your temples. A temple can hold up to as many birds as its cost (for example, 7 birds under a cost-7 temple).
Each bird still counts for match power +1 additional each, while nested. Nested birds cannot join bird fights. On the field, click the small stack tab beside a temple to see which birds are nested there.

Example (cards below): Wren starts on your field, then nests under Delpha — the stack tab shows how many birds are inside, matching the in-game layout."

[node name="ExampleBirdNestBeforeRow" type="HBoxContainer" parent="Margin/VBox/Scroll/ContentRoot"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 10

[node name="ExampleBirdNestAfterRow" type="HBoxContainer" parent="Margin/VBox/Scroll/ContentRoot"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 10

[node name="WinText" type="RichTextLabel" parent="Margin/VBox/Scroll/ContentRoot"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
scroll_active = false
text = "Win Conditions
- Reach 20 active Ritual power and you win immediately.
- If a player must draw from an empty deck, the game ends:
  - Higher active Ritual power wins.
  - If active Ritual power is tied, the game is a draw."

